{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "declaration": true,
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true
  },
  "include": [
    "src/index.ts",
    "src/core/**/*.ts",
    "src/profiles/**/*.ts",
    "src/adapters/**/*.ts"
  ]
}
