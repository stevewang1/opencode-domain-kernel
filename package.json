{
  "name": "opencode-domain-kernel",
  "version": "0.1.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/stevewang1/opencode-domain-kernel.git"
  },
  "homepage": "https://github.com/stevewang1/opencode-domain-kernel",
  "bugs": {
    "url": "https://github.com/stevewang1/opencode-domain-kernel/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.1.1",
    "@opencode-ai/sdk": "^1.1.1",
    "zod": "^4.1.8"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^5.7.3"
  }
}
